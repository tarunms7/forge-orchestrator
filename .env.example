# Forge Orchestrator — Environment Variables
# Copy to .env or export individually. All are optional with sensible defaults.

# ── Core ────────────────────────────────────
# FORGE_MODEL_STRATEGY=auto              # Model routing: auto, fast, quality
# FORGE_MAX_AGENTS=4                     # Max concurrent agent sessions
# FORGE_AGENT_TIMEOUT_SECONDS=600        # Per-task timeout in seconds
# FORGE_CONTEXT_ROTATION_TOKENS=80000    # Token limit before context rotation
# FORGE_MAX_RETRIES=5                    # Retries per task on failure
# FORGE_ALLOWED_DIRS=                    # Extra directories agents can access (comma-separated)

# ── Review Gates ────────────────────────────
# FORGE_BUILD_CMD=                       # Build command (auto-detected if unset)
# FORGE_TEST_CMD=                        # Test command (auto-detected if unset)
# FORGE_REQUIRE_APPROVAL=false           # Require human approval before merge

# ── Budget ──────────────────────────────────
# FORGE_BUDGET_LIMIT_USD=0               # Per-pipeline spend cap (0 = unlimited)

# ── Cost Rates (per 1K tokens, USD) ────────
# FORGE_COST_RATE_SONNET_INPUT=0.003
# FORGE_COST_RATE_SONNET_OUTPUT=0.015
# FORGE_COST_RATE_HAIKU_INPUT=0.00025
# FORGE_COST_RATE_HAIKU_OUTPUT=0.00125
# FORGE_COST_RATE_OPUS_INPUT=0.015
# FORGE_COST_RATE_OPUS_OUTPUT=0.075

# ── Web UI ──────────────────────────────────
# FORGE_JWT_SECRET=                      # JWT secret (unset = single-user mode)
# FORGE_AUTH_DISABLED=false              # Force single-user mode even with JWT secret
# FORGE_CORS_ORIGINS=http://localhost:3000  # Allowed CORS origins (comma-separated)

# ── Database ────────────────────────────────
# FORGE_DB_URL=sqlite+aiosqlite:///forge.db  # Database connection URL

# ── Resource Limits ─────────────────────────
# FORGE_CPU_THRESHOLD=80.0               # Max CPU % before backpressure
# FORGE_MEMORY_THRESHOLD_PCT=10.0        # Min available memory %
# FORGE_DISK_THRESHOLD_GB=5.0            # Min free disk space in GB

# ── Scheduling ──────────────────────────────
# FORGE_SCHEDULER_POLL_INTERVAL=1.0      # Scheduler poll interval in seconds
# FORGE_AUTO_UPDATE_CONVENTIONS=false    # Auto-update project conventions

# ── GitHub Webhooks ─────────────────────────
# FORGE_GITHUB_WEBHOOK_SECRET=           # GitHub webhook signing secret
# FORGE_GITHUB_ALLOWED_REPOS=            # Allowed repos for webhooks (comma-separated)
# FORGE_GITHUB_WEBHOOK_PROJECT_DIR=      # Project directory for webhook-triggered runs
