# Forge — environment configuration
# Copy to .env and customize as needed.
# All variables are optional — built-in defaults are shown.

# ── Core ──────────────────────────────────────────────────────────────────────
FORGE_DATA_DIR=                          # Default: ~/.local/share/forge
FORGE_DB_URL=                            # Default: sqlite+aiosqlite://${FORGE_DATA_DIR}/forge.db

# ── Parallelism & Timeouts ────────────────────────────────────────────────────
FORGE_MAX_AGENTS=5                       # Max concurrent agent sessions
FORGE_AGENT_TIMEOUT_SECONDS=600          # Per-task timeout in seconds (10 min)
FORGE_AGENT_MAX_TURNS=75                 # Max turns per agent execution
FORGE_MAX_RETRIES=5                      # Retries per task on failure
FORGE_PIPELINE_TIMEOUT_SECONDS=3600      # Pipeline timeout in seconds (0 = unlimited)
FORGE_SCHEDULER_POLL_INTERVAL=0.3        # Scheduler polling interval in seconds

# ── Model Routing ─────────────────────────────────────────────────────────────
FORGE_MODEL_STRATEGY=auto                # Model routing: auto, fast, quality

# ── Planning ──────────────────────────────────────────────────────────────────
FORGE_PLANNING_MODE=auto                 # Planning mode: auto, simple, deep

# ── Build, Test & Lint ────────────────────────────────────────────────────────
FORGE_BUILD_CMD=                         # Override auto-detected build command
FORGE_TEST_CMD=                          # Override auto-detected test command
FORGE_LINT_CMD=                          # Override lint check command
FORGE_LINT_FIX_CMD=                      # Override lint fix command

# ── Budget & Cost ─────────────────────────────────────────────────────────────
FORGE_BUDGET_LIMIT_USD=0                 # Per-pipeline spend cap in USD (0 = unlimited)

# ── Approval & Contracts ──────────────────────────────────────────────────────
FORGE_REQUIRE_APPROVAL=false             # Require human approval before merge
FORGE_AUTO_PR=false                      # Skip final approval, auto-create PR
FORGE_CONTRACTS_REQUIRED=false           # Require contracts for execution

# ── Human-in-the-loop ─────────────────────────────────────────────────────────
FORGE_AUTONOMY=balanced                  # Agent autonomy: full, balanced, supervised
FORGE_QUESTION_LIMIT=3                   # Max questions per task per execution cycle
FORGE_QUESTION_TIMEOUT=1800              # Seconds before auto-decide (30 min)

# ── Resource Thresholds ───────────────────────────────────────────────────────
FORGE_CPU_THRESHOLD=80.0                 # CPU % threshold for backpressure
FORGE_MEMORY_THRESHOLD_PCT=10.0          # Free memory % threshold for backpressure
FORGE_DISK_THRESHOLD_GB=5.0              # Free disk space threshold in GB

# ── Auth (web dashboard only) ─────────────────────────────────────────────────
FORGE_JWT_SECRET=                        # Required for web dashboard multi-user auth
FORGE_AUTH_DISABLED=false                # Disable auth (single-user dev mode)

# ── GitHub Webhook ────────────────────────────────────────────────────────────
FORGE_GITHUB_WEBHOOK_SECRET=             # GitHub webhook secret for verification
# FORGE_GITHUB_ALLOWED_REPOS=owner/repo1,owner/repo2
FORGE_GITHUB_WEBHOOK_PROJECT_DIR=        # Project directory for webhook-triggered runs
